{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  "autoClosingPairs": [
    {
      "open": "\"",
      "close": "\""
    },
    {
      "open": "'",
      "close": "'"
    },
    {
      "open": "`",
      "close": "`"
    },
    {
      "open": "{",
      "close": "}"
    }
  ],
  "surroundingPairs": [
    ["\"", "\""],
    ["'", "'"],
    ["`", "`"]
  ],
  "wordPattern": "(-?\\d*\\.\\d(?:ms|m|s)?|-?\\d+(?:\\.\\d+)?(?:ms|m|s)?)|([A-Za-z][A-Za-z0-9_]*)"
}
